# ─────────────────────────────────────────────────────────────────────────────
# ATRA Sovereign Trade Engine — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Environment & Secrets — CRITICAL: Never commit
.env
.env.local
.env.production
*.key
*.pem
*.p12

# Secure Vault — Partner documents (KYC, POF, signed SPAs)
backend/secure_vault/
!backend/secure_vault/.gitkeep

# Agent Logs — Daily Intelligence Reports
agents/logs/
!agents/logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
venv/
env/
.venv/
pip-cache/
.pytest_cache/
.mypy_cache/
*.coverage
htmlcov/

# Node / Frontend
node_modules/
.next/
.nuxt/
out/
dist/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Database
*.sqlite3
*.db
*.sql.dump

# Test outputs
.coverage
coverage.xml
*.lcov

# Build artifacts
*.tar.gz
*.zip
