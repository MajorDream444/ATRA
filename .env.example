# ─────────────────────────────────────────────────────────────────────────────
# ATRA Sovereign Trade Engine — Environment Variables
# Copy this file to .env and populate with your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_SECRET_KEY=CHANGE_ME_TO_RANDOM_256_BIT_HEX
APP_PORT=8000
APP_HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://atra_user:password@localhost:5432/atra_db
REDIS_URL=redis://localhost:6379/0

# ── Blacklist ─────────────────────────────────────────────────────────────────
BLACKLIST_PATH=data/blacklist/blacklist.json
BLACKLIST_SALT=CHANGE_ME_TO_RANDOM_SALT    # Used in hash derivation

# ── Settlement — Traditional ─────────────────────────────────────────────────
# (No secrets stored here — bank instructions go in secure_vault/)
ESCROW_PROVIDER_API_URL=
ESCROW_PROVIDER_API_KEY=

# ── Settlement — Digital Assets ───────────────────────────────────────────────
# CRITICAL: Never store private keys or seed phrases here.
# Use a Hardware Security Module (HSM) or KMS in production.
USDT_ERC20_WALLET_ADDRESS=
USDT_TRC20_WALLET_ADDRESS=
BTC_WALLET_ADDRESS=
WALLET_MULTISIG_REQUIRED_SIGNATURES=2      # M-of-N multisig

# ── Agent Intelligence Layer ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=                         # For Claude-powered agent intelligence
OPENAI_API_KEY=                            # Fallback / GPT-4o

# ── Port of Nouakchott Integration ────────────────────────────────────────────
PANPA_API_URL=
PANPA_API_KEY=

# ── Email / Notifications ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=m.diallo@atrasarl.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
LOG_PATH=agents/logs/
